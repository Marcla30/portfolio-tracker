# Database
POSTGRES_USER=portfolio
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=portfolio_tracker
DATABASE_URL=postgresql://portfolio:change_me_strong_password@db:5432/portfolio_tracker
PORT=3000
NODE_ENV=production

# Host port exposed by Docker (change if already in use on your machine)
APP_PORT=3000

# REQUIRED: Generate a long random string: openssl rand -base64 32
# This is REQUIRED and has no default fallback
SESSION_SECRET=generate-a-unique-random-string-here

# Set to true only if served over HTTPS (enables secure cookie flag)
COOKIE_SECURE=true

# REQUIRED: Allowed CORS origin for the API (your frontend domain)
# This is REQUIRED - must match your actual domain
CORS_ORIGIN=https://selfolio.app

# REQUIRED: JWT secret for mobile app auth (generate: openssl rand -base64 32)
# This is REQUIRED and has no default fallback
JWT_SECRET=generate-a-unique-random-string-here

REGISTRATION_ENABLED=true

# Push notifications — email used as sender identity for web-push
# VAPID keys are auto-generated and stored in DB, no need to set them here
VAPID_SUBJECT=mailto:your-email@example.com

# Cron schedule for wallet sync (default: every hour)
CRON_WALLET_SYNC_INTERVAL=0 * * * *

# Cron schedule for price snapshot (default: every 30 minutes)
# Examples: */15 * * * * (15min)  |  */30 * * * * (30min)  |  0 * * * * (1h)
PRICE_SNAPSHOT_INTERVAL=*/30 * * * *

# Steam Web API key (fully optional — both URL formats work without it)
# steamcommunity.com/profiles/76561... → direct extraction, no key needed
# steamcommunity.com/id/username     → resolved via public XML page, no key needed
# Set this only if you prefer to use the official ResolveVanityURL API
# Get one at https://steamcommunity.com/dev/apikey
# STEAM_API_KEY=your_steam_api_key_here
