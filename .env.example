DATABASE_URL=postgresql://portfolio:portfolio@db:5432/portfolio_tracker
PORT=3000
NODE_ENV=production

# Host ports exposed by Docker (change if already in use on your machine)
APP_PORT=3000
DB_PORT=5432

# Generate a long random string: openssl rand -base64 32
SESSION_SECRET=change-this-to-a-long-random-secret

REGISTRATION_ENABLED=true
DEFAULT_CURRENCY=EUR

# Push notifications — email used as sender identity for web-push
# VAPID keys are auto-generated and stored in DB, no need to set them here
VAPID_SUBJECT=mailto:your-email@example.com

# Cron schedule for wallet sync (default: every hour)
CRON_WALLET_SYNC_INTERVAL=0 * * * *
